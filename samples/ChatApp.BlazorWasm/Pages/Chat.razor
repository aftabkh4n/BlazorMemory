@page "/"
@using BlazorMemory.Core.Models
@using ChatApp.BlazorWasm.Models
@inject ChatService ChatService
@inject IJSRuntime JS

<PageTitle>BlazorMemory Demo</PageTitle>

<div class="app-shell">

    <!-- ── Sidebar: Memory Panel ─────────────────────────── -->
    <aside class="memory-panel @(ShowMemoryPanel ? "open" : "")">
        <div class="panel-header">
            <div class="panel-title">
                <span class="panel-icon">◈</span>
                Memory Store
            </div>
            <span class="memory-count">@Memories.Count stored</span>
        </div>

        <div class="panel-body">
            @if (LoadingMemories)
            {
                <div class="panel-loading">
                    <div class="spinner-small"></div>
                    <span>Loading memories...</span>
                </div>
            }
            else if (Memories.Count == 0)
            {
                <div class="panel-empty">
                    <div class="empty-icon">◇</div>
                    <p>No memories yet.</p>
                    <p class="empty-hint">Start chatting — facts about you will appear here.</p>
                </div>
            }
            else
            {
                <div class="memory-list">
                    @foreach (var memory in Memories)
                    {
                        <div class="memory-card">
                            <div class="memory-content">@memory.Content</div>
                            <div class="memory-meta">
                                <span class="memory-date">@FormatDate(memory.UpdatedAt ?? memory.LearnedAt)</span>
                                <button class="memory-delete" @onclick="() => DeleteMemory(memory.Id)" title="Delete">✕</button>
                            </div>
                        </div>
                    }
                </div>

                <button class="btn-clear" @onclick="ClearAllMemories">
                    Clear all memories
                </button>
            }
        </div>
    </aside>

    <!-- ── Main: Chat Area ───────────────────────────────── -->
    <main class="chat-area">

        <!-- Top bar -->
        <header class="chat-header">
            <div class="header-left">
                <div class="logo-mark">◈</div>
                <div class="header-title">
                    <span class="brand">BlazorMemory</span>
                    <span class="tagline">Demo — AI with persistent browser memory</span>
                </div>
            </div>
            <div class="header-right">
                @if (!ApiKeySet)
                {
                    <button class="btn-config active" @onclick="ToggleConfig">⚙ Set API Key</button>
                }
                else
                {
                    <button class="btn-config" @onclick="ToggleConfig">⚙ Config</button>
                }
                <button class="btn-memory-toggle" @onclick="ToggleMemoryPanel">
                    @(ShowMemoryPanel ? "Hide Memories" : "Show Memories")
                    <span class="memory-badge">@Memories.Count</span>
                </button>
            </div>
        </header>

        <!-- Config panel -->
        @if (ShowConfig)
        {
            <div class="config-bar">
                <div class="config-inner">
                    <label>OpenAI API Key</label>
                    <input type="password"
                           class="config-input"
                           placeholder="sk-..."
                           @bind="ApiKeyInput"
                           @bind:event="oninput" />
                    <button class="btn-save" @onclick="SaveApiKey">Save</button>
                </div>
                <p class="config-note">Your key is stored only in browser memory — never sent to any server except OpenAI.</p>
            </div>
        }

        <!-- Messages -->
        <div class="messages-area" @ref="MessagesRef">
            @if (Messages.Count == 0)
            {
                <div class="welcome">
                    <div class="welcome-icon">◈</div>
                    <h2>Memory-powered chat</h2>
                    <p>This assistant remembers facts about you across the entire conversation — stored locally in your browser's IndexedDB.</p>
                    <div class="welcome-hints">
                        <span class="hint">Try: "I'm a software engineer"</span>
                        <span class="hint">Try: "I prefer dark mode"</span>
                        <span class="hint">Try: "My name is Alex"</span>
                    </div>
                </div>
            }
            else
            {
                @foreach (var msg in Messages)
                {
                    <div class="message @msg.Role">
                        <div class="message-bubble">
                            <div class="message-text">@msg.Content</div>
                            <div class="message-time">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</div>
                        </div>
                    </div>
                }

                @if (IsLoading)
                {
                    <div class="message assistant">
                        <div class="message-bubble typing">
                            <span></span><span></span><span></span>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Error -->
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="error-bar">
                ⚠ @ErrorMessage
                <button @onclick="() => ErrorMessage = null">✕</button>
            </div>
        }

        <!-- Input -->
        <div class="input-area">
            <div class="input-box">
                <textarea
                    class="message-input"
                    placeholder="@(ApiKeySet ? "Say something…" : "Set your OpenAI API key above to start")"
                    rows="1"
                    @bind="InputText"
                    @bind:event="oninput"
                    @onkeydown="HandleKeyDown"
                    disabled="@(!ApiKeySet || IsLoading)"
                    @ref="InputRef">
                </textarea>
                <button class="send-btn"
                        @onclick="SendMessage"
                        disabled="@(string.IsNullOrWhiteSpace(InputText) || IsLoading || !ApiKeySet)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M22 2L11 13M22 2L15 22L11 13M22 2L2 9L11 13"/>
                    </svg>
                </button>
            </div>
            <p class="input-hint">Memories are extracted and stored in your browser automatically.</p>
        </div>

    </main>
</div>
