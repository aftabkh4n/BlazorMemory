@page "/"
@using BlazorMemory.Components
@using ChatApp.BlazorWasm.Models

<PageTitle>BlazorMemory Demo</PageTitle>

<div class="app-shell">

    <MemoryPanel UserId="demo_user"
                 IsOpen="ShowMemoryPanel"
                 @ref="_memoryPanel" />

    <main class="chat-area">

        <header class="chat-header">
            <div class="header-left">
                <div class="logo-mark">◈</div>
                <div class="header-title">
                    <span class="brand">BlazorMemory</span>
                    <span class="tagline">Demo — AI with persistent browser memory</span>
                </div>
            </div>
            <div class="header-right">
                @if (!ApiKeySet)
                {
                    <button class="btn-config active" @onclick="ToggleConfig">⚙ Set API Key</button>
                }
                else
                {
                    <button class="btn-config" @onclick="ToggleConfig">⚙ Config</button>
                }
                <button class="btn-memory-toggle" @onclick="ToggleMemoryPanel">
                    @(ShowMemoryPanel ? "Hide Memories" : "Show Memories")
                </button>
            </div>
        </header>

        @if (ShowConfig)
        {
            <div class="config-bar">
                <div class="config-inner">
                    <label>OpenAI API Key</label>
                    <input type="password"
                           class="config-input"
                           placeholder="sk-..."
                           @bind="ApiKeyInput"
                           @bind:event="oninput" />
                    <button class="btn-save" @onclick="SaveApiKey">Save</button>
                </div>
                <p class="config-note">Your key is stored only in browser memory — never sent to any server except OpenAI.</p>
            </div>
        }

        <div class="messages-area" @ref="MessagesRef">
            @if (Messages.Count == 0)
            {
                <div class="welcome">
                    <div class="welcome-icon">◈</div>
                    <h2>Memory-powered chat</h2>
                    <p>This assistant remembers facts about you across the entire conversation — stored locally in your browser's IndexedDB.</p>
                    <div class="welcome-hints">
                        <span class="hint">Try: "I'm a software engineer"</span>
                        <span class="hint">Try: "I prefer dark mode"</span>
                        <span class="hint">Try: "My name is Alex"</span>
                    </div>
                </div>
            }
            else
            {
                for (int i = 0; i < Messages.Count; i++)
                {
                    var msg   = Messages[i];
                    var msgId = "msg_" + i;

                    <div class="message @msg.Role">
                        <div class="message-bubble">
                            <div class="message-text">@msg.Content</div>
                            <div class="message-footer">
                                <span class="message-time">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</span>
                                <button class="copy-btn @(CopiedId == msgId ? "copied" : "")"
                                        @onclick="() => CopyMessage(msg.Content, msgId)"
                                        title="Copy">
                                    @if (CopiedId == msgId)
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="13" height="13">
                                            <path d="M20 6L9 17l-5-5"/>
                                        </svg>
                                        <span>Copied</span>
                                    }
                                    else
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                                            <rect x="9" y="9" width="13" height="13" rx="2"/>
                                            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                                        </svg>
                                        <span>Copy</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>
                }

                @if (IsLoading)
                {
                    <div class="message assistant">
                        <div class="message-bubble typing">
                            <span></span><span></span><span></span>
                        </div>
                    </div>
                }
            }
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="error-bar">
                ⚠ @ErrorMessage
                <button @onclick="() => ErrorMessage = null">✕</button>
            </div>
        }

        <div class="input-area">
            <div class="input-box">
                <textarea
                    class="message-input"
                    placeholder="@(ApiKeySet ? "Say something…" : "Set your OpenAI API key above to start")"
                    rows="1"
                    @bind="InputText"
                    @bind:event="oninput"
                    @onkeydown="HandleKeyDown"
                    disabled="@(!ApiKeySet || IsLoading)"
                    @ref="InputRef">
                </textarea>
                <button class="send-btn"
                        @onclick="SendMessage"
                        disabled="@(string.IsNullOrWhiteSpace(InputText) || IsLoading || !ApiKeySet)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M22 2L11 13M22 2L15 22L11 13M22 2L2 9L11 13"/>
                    </svg>
                </button>
            </div>
            <p class="input-hint">Memories are extracted and stored in your browser automatically.</p>
        </div>

    </main>
</div>
